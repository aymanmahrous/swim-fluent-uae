# Client-safe Supabase configuration (RLS must be enabled)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Internal UI feature flags. Keep false in production until staff auth/RBAC exists.
VITE_ENABLE_AI_OS=false
VITE_ENABLE_LEGACY_ADMIN=false
VITE_AI_OS_DEMO_DATA=false

# SERVER ONLY — never expose with VITE_ or commit real values
SUPABASE_SERVICE_ROLE_KEY=server-secret-only
AI_TEXT_API_KEY=server-secret-only
AI_IMAGE_API_KEY=server-secret-only
AI_VIDEO_API_KEY=server-secret-only
META_APP_SECRET=server-secret-only
WHATSAPP_ACCESS_TOKEN=server-secret-only
TIKTOK_CLIENT_SECRET=server-secret-only
