# Client-safe Supabase configuration (RLS must be enabled)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Public navigation feature flags. AI OS itself is protected by Staff Auth/RBAC.
VITE_ENABLE_AI_OS=false
VITE_ENABLE_LEGACY_ADMIN=false
VITE_AI_OS_DEMO_DATA=false

# SERVER ONLY — never expose with VITE_ or commit real values
# Modern Supabase sb_secret_... key for trusted backend publishing workers only.
SUPABASE_SECRET_KEY=server-secret-only
INTERNAL_WORKER_TOKEN=server-secret-only

# Alibaba Model Studio — Qwen text + Wan image/video adapters
MAAS_ENDPOINT=https://your-workspace.ap-southeast-1.maas.aliyuncs.com
ALIBABA_MODEL_STUDIO_API_KEY=server-secret-only
AI_TEXT_PROVIDER=alibaba-qwen
AI_TEXT_MODEL=qwen3.7-max
AI_IMAGE_PROVIDER=alibaba-wan-image
AI_IMAGE_MODEL=wan2.7-image-pro
AI_VIDEO_PROVIDER=alibaba-wan-video
AI_VIDEO_TEXT_MODEL=wan2.7-t2v-2026-06-12
AI_VIDEO_IMAGE_MODEL=wan2.7-i2v-2026-04-25

# Optional generic provider credentials for future non-Alibaba adapters
AI_TEXT_API_KEY=server-secret-only
AI_IMAGE_API_KEY=server-secret-only
AI_VIDEO_API_KEY=server-secret-only

# External messaging and publishing providers
META_APP_ID=server-config-only
META_APP_SECRET=server-secret-only
META_VERIFY_TOKEN=server-secret-only
WHATSAPP_PHONE_NUMBER_ID=server-config-only
WHATSAPP_ACCESS_TOKEN=server-secret-only
TIKTOK_CLIENT_KEY=server-config-only
TIKTOK_CLIENT_SECRET=server-secret-only
